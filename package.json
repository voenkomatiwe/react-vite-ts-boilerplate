{
  "name": "vite-template",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "bun typecheck && biome lint --fix",
    "format": "biome format --write",
    "check": "biome check --fix",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/vite": "4.2.2",
    "clsx": "2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "7.13.2",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react-swc": "4.3.0",
    "husky": "9.1.7",
    "lightningcss": "1.32.0",
    "lint-staged": "16.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vite-tsconfig-paths": "6.1.1"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,md}": [
      "biome check --fix --files-ignore-unknown=true"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
